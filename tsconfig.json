{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "strict": true,
    "noEmit": true
  },
  "include": [
    "playwright.config.ts",
    "config/**/*.ts",
    "constants/**/*.ts",
    "api/**/*.ts",
    "fixtures/**/*.ts",
    "pages/**/*.ts",
    "payloads/**/*.ts",
    "tests/**/*.ts"
  ]
}
